{
  "files.eol": "\n",
  "files.associations": {
    "*.css": "tailwindcss"
  },
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },
  "eslint.validate": ["javascript", "typescript", "vue"],
  "[vue]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "tailwindCSS.files.exclude": ["**/components/ui/**"],
  "tailwindCSS.experimental.classRegex": [
    ["cva\\(([^)]*)\\)", "[\"'`]([^\"'`]*).*?[\"'`]"],
    ["cn\\(([^)]*)\\)", "[\"'`]([^\"'`]*).*?[\"'`]"]
  ],
  "cSpell.useGitignore": true,
  "cSpell.ignorePaths": [
    ".gitignore",
    "package-lock.json",
    "pnpm-lock.yaml",
    "yarn.lock",
    ".vscode/**",
    "src/components/ui/**",
    "src/style.css"
  ],
  "cSpell.words": [
    "angellist",
    "bamboohr",
    "BCBSNC",
    "BCBSSC",
    "Blackbaud",
    "castandcrew",
    "Cengage",
    "checkmark",
    "classroommosaic",
    "Computeds",
    "customsite",
    "Dataman",
    "duckcreek",
    "Excelraise",
    "flexjobs",
    "Glassdoor",
    "Globex",
    "governmentjobs",
    "gunio",
    "hackernews",
    "homedepot",
    "Hooli",
    "Initech",
    "jobboards",
    "Ksystems",
    "levelsfyi",
    "lucide",
    "myworkdayjobs",
    "noopener",
    "noreferrer",
    "nums",
    "oldco",
    "reka",
    "remoteco",
    "remoteok",
    "reposts",
    "roberthalf",
    "sefl",
    "sitea",
    "siteb",
    "Softdocs",
    "sonner",
    "spglobal",
    "stackoverflow",
    "Systemtec",
    "techco",
    "techjobsforgood",
    "teksystems",
    "Toptal",
    "Upwork",
    "usajobs",
    "vaul",
    "vueuse",
    "Wellfound",
    "weworkremotely",
    "whoishiring",
    "ziprecruiter"
  ],
  "terminal.integrated.scrollback": 25000,
  "typescript.preferences.preferTypeOnlyAutoImports": true,
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.patterns": {
    "*.vue": "${capture}.test.ts, index.ts",
    "*.ts": "${capture}.test.ts"
  }
}
