// tsconfig.typecheck.json
{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "jsxImportSource": "vue",
    "noEmit": true
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.vue"],
  "exclude": [
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/test-utils/**/*",
    "src/components/ui/**/*",
    "node_modules"
  ]
}
